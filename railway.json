{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && npm install",
    "watchPatterns": ["server/**"]
  },
  "deploy": {
    "startCommand": "cd server && node index.js",
    "healthcheckPath": "/api/products",
    "restartPolicyType": "ON_FAILURE"
  }
}
